{
  "enabled": {
    "description": "是否启用动态人格插件",
    "type": "bool",
    "default": true
  },
  "persona_bindings": {
    "description": "人格绑定规则",
    "type": "template_list",
    "hint": "配置匹配条件与人格的绑定关系。匹配成功后将完全替换人格设置（包括 tools、skills、begin_dialogs、custom_error_message 等）",
    "templates": {
      "binding_rule": {
        "name": "绑定规则",
        "hint": "配置匹配条件和对应人格",
        "items": {
          "rule_enabled": {
            "description": "是否启用该规则",
            "type": "bool",
            "default": true
          },
          "rule_name": {
            "description": "规则名称",
            "type": "string",
            "default": "",
            "hint": "可选，用于在日志中识别该规则"
          },
          "match_conditions": {
            "description": "匹配条件（每行一个）",
            "type": "text",
            "default": "",
            "hint": "格式：群ID/发送者ID（精确匹配）、p_发送者ID（匹配发送者）、g_群ID（匹配群）。每行一个条件，任一匹配即生效"
          },
          "persona_id": {
            "description": "关联的人格",
            "type": "string",
            "_special": "select_persona",
            "hint": "匹配成功时使用的人格（将完全替换人格设置）"
          },
          "provider_id": {
            "description": "该人格使用的对话模型配置",
            "type": "string",
            "_special": "select_provider",
            "hint": "留空则跟随当前会话",
            "default": ""
          }
        }
      }
    }
  }
}
